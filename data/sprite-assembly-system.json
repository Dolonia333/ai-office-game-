      "total_size": { "w": 192, "h": 64 }
    },
    "bookshelf_tall": {
      "description": "2-piece tall bookshelf",
      "pieces": [
        "bookshelf_top",
        "bookshelf_bottom"
      ],
      "assembly_rule": "Top and bottom must be stacked vertically (Y offset: +64px between them).",
      "breaking_rule": "Using either piece alone looks incomplete/floating."
    },
    "cubicle_pod_set": {
      "description": "All pieces needed for cubicle divider system",
      "pieces": [
        "cubicle_divider_horizontal",
        "cubicle_endcap_vertical"
      ],
      "assembly_rule": "Dividers sit on top of desks. End-caps close left/right sides."
    }
  },

  "placement_rules": {
    "desktop_items_offset": {
      "rule": "Items placed ON desks must be Y-offset (-10 to -20px) so they appear sitting on surface, not floating in middle",
      "examples": [
        "monitor_dual (y_offset: -15)",
        "desk_lamp_on_angle1 (y_offset: -16)",
        "paperwork_stack (y_offset: -12)"
      ]
    },
    "chair_placement": {
      "rule": "Chairs placed BELOW desk (z_index 1). Standard offset: Y_desk + 64px",
      "orientation_rule": "Use 'back' facing for standard cubicles, 'front' facing for meeting tables"
    },
    "divider_placement": {
      "rule": "Dividers sit ABOVE desk surfaces (z_index 3). Placement: Y_desk - 64px",
      "critical_note": "If divider is omitted, cubicle looks unfinished/exposed"
    },
    "wall_mounted_items": {
      "rule": "Whiteboards, posters, diplomas must be placed on wall surfaces (z_index 3), not on floor",
      "examples": [
        "whiteboard_blank",
        "poster_pop_art",
        "diploma_certificate"
      ]
    },
    "modular_furniture_assembly": {
      "rule": "Modular pieces (sofas, bookshelves) must NEVER be used partially",
      "example": "Sofa must have: [left_end + repeatable_middles + right_end]. Never place middle alone.",
      "enforcement": "System should validate that modular groups are complete before rendering"
    }
  },

