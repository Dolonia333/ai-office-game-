{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "Pixel Office Sprite Assembly System",
    "description": "Complete technical blueprint for building office layouts without 'broken' sprites. All coordinates from Modern Office sprite sheet (64x64 grid). Includes modular groupings, stacking order, and assembly rules.",
    "sheet_size_px": "64x64 tiles",
    "coordinate_system": "Top-left anchor (x, y) in pixels",
    "credit": "Modern Office Revamped v1.2 by LimeZu"
  },

  "z_index_layers": {
    "0": { "name": "Floor", "description": "Carpet/tile base textures", "examples": ["floor_tile_grey_grid"] },
    "1": { "name": "Under-Furniture", "description": "Chairs (when not sitting), items below desks", "examples": ["office_chair_grey_back"] },
    "2": { "name": "Furniture Base", "description": "Desk surfaces, tables, seating anchors", "examples": ["desk_tan_horizontal", "desk_grey_horizontal"] },
    "3": { "name": "Partitions & Walls", "description": "Dividers, end-caps, wall-mounted items", "examples": ["cubicle_divider_horizontal", "cubicle_endcap_vertical"] },
    "4": { "name": "Desktop Items", "description": "Monitors, lamps, papers (Y-offset -10 to -20px)", "examples": ["monitor_dual_light_grey", "desk_lamp"] },
    "5": { "name": "Characters", "description": "NPCs and player character", "examples": ["character_sprite"] }
  },

