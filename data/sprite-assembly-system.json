      "color": "grey"
    },
    "sofa_grey_3piece": {
      "description": "3-piece modular grey sofa",
      "pieces": [
        "sofa_grey_left",
        "sofa_grey_middle",
        "sofa_grey_right"
      ],
      "assembly_rule": "CRITICAL: Must always have left + right ends. Middle can repeat for longer seating.",
      "breaking_rule": "Using only middle tile breaks sofa appearance. Always include ends.",
      "total_size": { "w": 192, "h": 64 }
    },
    "sofa_tan_3piece": {
      "description": "3-piece modular tan sofa",
      "pieces": [
        "sofa_tan_left",
        "sofa_tan_middle",
        "sofa_tan_right"
      ],
      "assembly_rule": "CRITICAL: Must always have left + right ends.",
